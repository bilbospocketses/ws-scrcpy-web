{
  "name": "ws-scrcpy-web",
  "version": "1.0.0",
  "description": "Browser-based Android screen mirroring and control, powered by scrcpy",
  "license": "GPL-3.0-only",
  "author": "bilbospocketses",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bilbospocketses/ws-scrcpy-web.git"
  },
  "bugs": {
    "url": "https://github.com/bilbospocketses/ws-scrcpy-web/issues"
  },
  "homepage": "https://github.com/bilbospocketses/ws-scrcpy-web#readme",
  "keywords": [
    "scrcpy",
    "android",
    "screen-mirroring",
    "adb",
    "websocket",
    "webcodecs",
    "remote-control",
    "android-tv"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:dev": "webpack --config webpack/ws-scrcpy-web.dev.ts --stats-error-details",
    "build": "webpack --config webpack/ws-scrcpy-web.prod.ts --stats-error-details && npm run build:types",
    "build:types": "node scripts/build-types.js",
    "start": "npm run build && node dist/index.js",
    "test": "vitest run",
    "lint": "npx @biomejs/biome check src/",
    "format": "npx @biomejs/biome check --write src/"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.12.2",
    "@types/ws": "^8",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "css-loader": "^7.1.4",
    "dts-bundle-generator": "^9.5.1",
    "jsdom": "^29.0.2",
    "mini-css-extract-plugin": "^2.6.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
