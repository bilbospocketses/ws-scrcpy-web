{
  "name": "ws-scrcpy-web",
  "version": "1.0.0",
  "description": "Browser-based Android screen mirroring and control, powered by scrcpy",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:dev": "webpack --config webpack/ws-scrcpy-web.dev.ts --stats-error-details",
    "build": "webpack --config webpack/ws-scrcpy-web.prod.ts --stats-error-details",
    "start": "npm run build && node dist/index.js",
    "test": "vitest run",
    "lint": "npx @biomejs/biome check src/",
    "format": "npx @biomejs/biome check --write src/"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.12.2",
    "@types/ws": "^8",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "css-loader": "^7.1.4",
    "mini-css-extract-plugin": "^2.6.1",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
